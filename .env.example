# Core paths
PROJECT_ROOT=/workspaces/regional_infrastructure_resilence_auditor
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
DUCKDB_PATH=data/processed/regional_resilience.duckdb

# dbt + DuckDB
DBT_PROFILES_DIR=dbt
DBT_TARGET=dev

# Airflow
AIRFLOW_HOME=airflow
AIRFLOW__CORE__DAGS_FOLDER=airflow/dags
AIRFLOW__CORE__LOAD_EXAMPLES=False

# Dashboard
STREAMLIT_SERVER_PORT=8501

# SLA Monitoring Thresholds
SLA_MAX_PREDICTION_STALENESS_DAYS=30
SLA_MIN_COMPLETENESS_RATE=0.85
SLA_MAX_ROWCOUNT_DELTA_RATIO=0.25